**/alembic/__pycache__/
**/migrations/__pycache__/
*.pyc

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Docker / Compose local overrides ---
docker-compose.override.yml

