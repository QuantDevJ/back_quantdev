# --- Logs / local runtime files ---
*.log
*.pid

# --- Local secrets / environment files ---
.env
.env.*
!.env.example
!.env.sample

# --- FastAPI/Uvicorn/Starlette ---
*.sqlite3
instance/

# --- Alembic ---
