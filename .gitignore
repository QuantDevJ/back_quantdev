# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.conda/
.python-version

# --- Packaging / build artifacts ---
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- Test / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
junit.xml

# --- Type checking / linters ---
.mypy_cache/
.pyre/
.pytype/
